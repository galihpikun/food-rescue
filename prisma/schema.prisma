generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["partialIndexes"]
}

datasource db {
  provider = "postgresql"
}

model users {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  username   String
  email      String   @unique
  password   String
  role       String   @default("user")
  avatar     String?
  created_at DateTime @default(now()) @db.Timestamptz(6)
}
